<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer gradient border -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="180"
                android:startColor="#FF5722"
                android:centerColor="#E91E63"
                android:endColor="#6B1FB1"/>
        </shape>
    </item>

    <!-- Inner white (or background) circle -->
    <item
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp">
        <shape android:shape="oval">
            <solid android:color="@android:color/white"/>
        </shape>
    </item>

</layer-list>
