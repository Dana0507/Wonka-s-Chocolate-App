<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pink"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">


    <!-- Background Image for pfp-->

    <ImageView
        android:id="@+id/bg_pfp"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_rounded_bottom"
        android:clipToOutline="true"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toTopOf="@+id/linearLayout2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/purpswirl" />


    <!-- Profile Image (rounded) -->
    <!-- layout height must not be zero!! it should be equal to width -->
    <FrameLayout
        android:id="@+id/frameLayout_pfp"
        android:layout_width="115dp"
        android:layout_height="115dp"
        android:layout_marginTop="68dp"
        android:layout_marginBottom="17dp"
        android:background="@drawable/pfp_gradient_border"
        android:clipToPadding="false"
        android:padding="5dp"
        app:layout_constraintBottom_toTopOf="@+id/profile_username"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_editor_absoluteX="148dp"
        app:layout_editor_absoluteY="68dp">

        <!-- Circular clipped image -->
        <ImageView
            android:id="@+id/pfp"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/pfp_circle_clip"
            android:clipToOutline="true"
            android:scaleType="centerCrop"
            android:src="@drawable/default_pfp" />

        <!-- EDIT BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_edit_pfp"
            android:layout_width="33dp"
            android:layout_height="40dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="0dp"
            android:layout_marginBottom="-4dp"
            android:contentDescription="Edit Profile Picture"
            android:padding="6dp"
            app:backgroundTint="@color/pink"
            app:cornerRadius="100dp"
            app:icon="@drawable/baseline_camera_alt_24"
            app:iconGravity="textEnd"
            app:iconPadding="0dp"
            app:iconTint="@color/black" />

    </FrameLayout>


    <TextView
        android:id="@+id/profile_username"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="7dp"
        android:fontFamily="@font/willywonka"
        android:gravity="center"
        android:text="Username"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textSize="35sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/linearLayout2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/frameLayout_pfp" />


    <!-- Floating card -->
    <LinearLayout
        android:id="@+id/linearLayout2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"

        android:layout_marginBottom="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/profile_username">

        <androidx.cardview.widget.CardView
            android:id="@+id/floatingCard_userinfo"
            android:layout_width="347dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="@android:color/white"
            android:padding="24dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="15dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/contact_info_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:drawableStart="@android:drawable/sym_action_email"
                        android:drawablePadding="8dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:text="Contact Info"
                        android:textColor="@color/purple"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <!-- Edit Contact Info Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_edit_contact"
                        android:layout_width="35dp"
                        android:layout_height="35dp"
                        android:layout_alignParentEnd="true"
                        android:contentDescription="Edit Contact Info"
                        android:padding="6dp"
                        android:visibility="visible"
                        app:backgroundTint="@color/purple"
                        app:cornerRadius="8dp"
                        app:icon="@drawable/outline_border_color_24"
                        app:iconGravity="textEnd"
                        app:iconPadding="0dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save_contact"
                        android:layout_width="35dp"
                        android:layout_height="35dp"
                        android:layout_alignParentEnd="true"
                        android:visibility="invisible"
                        app:backgroundTint="@color/green"
                        app:cornerRadius="8dp"
                        app:icon="@drawable/outline_check_24"
                        app:iconGravity="textStart"
                        app:iconPadding="0dp"
                        app:iconTint="@android:color/white" />


                </RelativeLayout>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/email_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:gravity="center"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:text="Email:"
                        android:textColor="@color/purple"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/user_email"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:gravity="center"
                        android:text="username@gmail.com"
                        android:textColor="@color/grey_text"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:visibility="visible" />

                    <EditText
                        android:id="@+id/edit_user_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/grey_text"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:visibility="gone" />


                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/phone_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:gravity="center"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:text="Phone:"
                        android:textColor="@color/purple"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/user_phone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:gravity="center"
                        android:text="01010101"
                        android:textColor="@color/grey_text"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:visibility="visible" />

                    <EditText
                        android:id="@+id/edit_user_phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/grey_text"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:visibility="gone" />


                </LinearLayout>

                <LinearLayout
                    android:id="@+id/username_ed_layout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tv_ed_username"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:text="Username: "
                        android:textColor="@color/purple"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <EditText
                        android:id="@+id/editTextText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ems="8"
                        android:inputType="text"
                        android:text=""
                        android:textColor="@color/grey_text"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/floatingCard_favorites"
            android:layout_width="347dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="@android:color/white"
            android:padding="24dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="15dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">


                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/favorites_tv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentStart="true"
                            android:layout_marginBottom="16dp"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:text="⭐ My Favorites"
                            android:textColor="@color/purple"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_view_all_favorites"
                            android:layout_width="35dp"
                            android:layout_height="35dp"
                            android:layout_alignParentEnd="true"
                            android:contentDescription="View All Favorites"
                            android:padding="5dp"
                            app:backgroundTint="@color/purple"
                            app:cornerRadius="8dp"
                            app:icon="@drawable/baseline_arrow_outward_24"
                            app:iconGravity="textEnd"
                            app:iconPadding="0dp" />

                    </RelativeLayout>


                </LinearLayout>

                <!-- RecyclerView inside Card (Horizontal scroll) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_favorites"
                    android:layout_width="match_parent"
                    android:layout_height="170dp"
                    android:overScrollMode="never"
                    android:padding="5dp"
                    tools:listitem="@layout/item_favorite" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Floating card -->


</androidx.constraintlayout.widget.ConstraintLayout>