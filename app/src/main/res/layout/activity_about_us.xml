<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/purpleback"
    android:padding="30dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingTop="80dp"
        android:paddingBottom="30dp">

        <!-- Title -->
        <TextView
            android:id="@+id/aboutTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" How this Adventure App Was Born "
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:fontFamily="@font/willywonka"
            android:textAlignment="center"
            android:layout_marginBottom="24dp"/>

        <Space
            android:layout_width="match_parent"
            android:layout_height="30dp" />

        <!-- Story Card 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/rounded_card"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:text="After Charlie’s magical chocolate adventure, he wondered: why not make magical places available for everyone? "
                android:textColor="@android:color/white"
                android:textSize="18sp" />
        </LinearLayout>

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/down"
            android:layout_marginBottom="16dp"
            android:contentDescription="down arrow" />


        <!-- Story Card 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_card"
            android:padding="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="With a pinch of imagination and a dash of chocolate, the Adventure App was born! 🍬"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:lineSpacingExtra="4dp"/>
        </LinearLayout>

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/down"
            android:layout_marginBottom="16dp"
            android:contentDescription="down arrow" />

        <!-- Story Card 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_card"
            android:padding="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:text="Now, every journey is sweet, simple, and full of surprises! 🎩"
                android:textColor="@android:color/white"
                android:textSize="18sp" />

        </LinearLayout>
        <Space
            android:layout_width="match_parent"
            android:layout_height="30dp" />

        <!-- Back Button -->
        <Button
            android:id="@+id/btnGoback"
            android:layout_width="322dp"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#d39c1d"
            android:elevation="6dp"
            android:letterSpacing="0.02"
            android:text="Go Back"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>