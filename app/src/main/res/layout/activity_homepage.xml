<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/purpswirl"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/descriptionText"
            android:layout_width="382dp"
            android:layout_height="wrap_content"
            android:fontFamily="@font/willywonka"
            android:paddingTop="100dp"
            android:paddingBottom="80dp"
            android:shadowColor="#66000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:text="Pick an adventure and let the chocolate magic begin!"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="34sp" />

        <!-- All buttons same width & height with emojis -->
        <Button
            android:id="@+id/btnLearn"
            android:layout_width="322dp"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#d39c1d"
            android:elevation="6dp"
            android:letterSpacing="0.02"
            android:text="🍭 Learn About Us"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnShopChocolate"
            android:layout_width="322dp"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#d39c1d"
            android:elevation="6dp"
            android:letterSpacing="0.02"
            android:text="🛒 Shop Your Chocolate"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCreateChocolate"
            android:layout_width="322dp"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#d39c1d"
            android:elevation="6dp"
            android:letterSpacing="0.02"
            android:text="🍫 Customize Your Chocolate Bar"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnGoldenTicket"
            android:layout_width="322dp"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#d39c1d"
            android:elevation="6dp"
            android:letterSpacing="0.02"
            android:text="🎫 Scan Your Golden Ticket"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>