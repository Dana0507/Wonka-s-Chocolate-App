<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/purpleback"
    tools:context=".chooseFills"
    android:paddingTop="80dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">
        <!-- Title -->
        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/willywonka"
            android:text="Make Your Own Chocolate"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Navigation Buttons -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="54dp"
            android:layout_height="41dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="80dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:padding="8dp"
            android:src="@drawable/left"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/btnNext"
            android:layout_width="54dp"
            android:layout_height="41dp"
            android:layout_marginTop="80dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Next"
            android:padding="8dp"
            android:src="@drawable/right"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/willywonka"
            android:text="Choose the shape"
            android:textColor="#F6C90E"
            android:textSize="27sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/titleText" />

        <!-- Swirly Background (centered full width) -->
        <ImageView
            android:id="@+id/swirlyBackground"
            android:layout_width="0dp"
            android:layout_height="400dp"
            android:layout_marginStart="-16dp"
            android:layout_marginEnd="-16dp"
            android:layout_marginTop="40dp"
            android:alpha="0.25"
            android:scaleType="fitCenter"

            app:layout_constraintTop_toBottomOf="@id/subtitleText"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- RadioGroup (on top of swirly) -->

        <!-- Melting image (below RadioGroup, faded) -->
        <RadioGroup
            android:id="@+id/shapeRadioGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/swirlyBackground"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.497"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/swirlyBackground"
            app:layout_constraintVertical_bias="0.325">

            <RadioButton
                android:id="@+id/radioHeart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:buttonTint="@color/golden_yellow"

                android:text="Heart"
                android:textColor="#FFFFFF"
                android:textSize="30sp" />

            <RadioButton
                android:id="@+id/radioStar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:buttonTint="@color/golden_yellow"

                android:text="Star"
                android:textColor="#FFFFFF"
                android:textSize="30sp" />

            <RadioButton
                android:id="@+id/radioTriangle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:buttonTint="@color/golden_yellow"

                android:text="Triangle"
                android:textColor="#FFFFFF"
                android:textSize="30sp" />

            <RadioButton
                android:id="@+id/radioHexagon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:buttonTint="@color/golden_yellow"

                android:text="Moon"
                android:textColor="#FFFFFF"
                android:textSize="30sp" />

            <RadioButton
                android:id="@+id/radioDiamond"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:buttonTint="@color/golden_yellow"
                android:text="Diamond"
                android:textColor="#FFFFFF"
                android:textSize="30sp" />

            <RadioButton
                android:id="@+id/radioRectangle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:buttonTint="@color/golden_yellow"

                android:text="Rectangle"
                android:textColor="#FFFFFF"
                android:textSize="30sp" />
        </RadioGroup>

        <ImageView
            android:id="@+id/melting"
            android:layout_width="160dp"
            android:layout_height="140dp"
            android:layout_marginTop="56dp"
            android:alpha="0.6"
            android:contentDescription="Melting chocolate"
            android:src="@drawable/melting"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.958"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/shapeRadioGroup" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>